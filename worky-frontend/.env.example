# ==============================================================================
# Worky Frontend — Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and fill in all required values before running.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control — it is listed in .gitignore.
# This file (.env.example) is safe to commit — it contains no real secrets.
# ==============================================================================


# ------------------------------------------------------------------------------
# Backend API
# ------------------------------------------------------------------------------

# Base URL of the Worky backend.
# Must match the server the FastAPI backend is running on.
# The backend's CORS configuration allows requests from http://localhost:3000,
# so the frontend dev server must run on port 3000.
VITE_API_BASE_URL=http://localhost:8000
