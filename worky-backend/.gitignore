# ==============================================================================
# Worky Backend — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment variables — NEVER commit real secrets
# ------------------------------------------------------------------------------
.env
.env.local
.env.development
.env.staging
.env.production
.env.test

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Distribution and packaging
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl
MANIFEST
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
nosetests.xml
test-results/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
pyrightconfig.json

# Linters and formatters
.ruff_cache/

# ------------------------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ------------------------------------------------------------------------------
# IDE and editors
# ------------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Operating systems
# ------------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
logs/
*.out

# ------------------------------------------------------------------------------
# Databases and local storage
# ------------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal

# ------------------------------------------------------------------------------
# Security — certificates and keys (never commit)
# ------------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
.dockerignore

# ------------------------------------------------------------------------------
# Node / Electron (future desktop app)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------------------------
tmp/
temp/
.tmp/
*.tmp
*.temp
*.bak
*.orig
*.rej

# ------------------------------------------------------------------------------
# FastAPI / Uvicorn
# ------------------------------------------------------------------------------
.uvicorn.log

# ------------------------------------------------------------------------------
# Redis dump (if running locally)
# ------------------------------------------------------------------------------
dump.rdb
