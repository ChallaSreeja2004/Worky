# ==============================================================================
# Worky Backend — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in all required values before running.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — it is listed in .gitignore.
# This file (.env.example) is safe to commit — it contains no real secrets.
# ==============================================================================


# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

APP_NAME=worky-backend
APP_ENV=development
APP_PORT=8000


# ------------------------------------------------------------------------------
# API
# ------------------------------------------------------------------------------

# Versioned API prefix — all routes are mounted under this path.
API_V1_PREFIX=/api/v1


# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------

# Base URL of the React / desktop widget frontend.
# When set, the OAuth callback redirects the browser to:
#   {FRONTEND_URL}/auth/success?user_id=...&display_name=...&email=...
# When left empty, the callback returns AuthorizationResponse JSON instead
# (backward-compatible default — safe for API clients and automated tests).
# Must NOT have a trailing slash.
FRONTEND_URL=http://localhost:3000


# ------------------------------------------------------------------------------
# Security — Token Encryption
# ------------------------------------------------------------------------------

# Fernet symmetric key used to encrypt OAuth refresh tokens before persistence.
# Generate a key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key invalidates all stored refresh tokens — users must re-login.
TOKEN_ENCRYPTION_KEY=


# ------------------------------------------------------------------------------
# Microsoft Outlook (app/connectors/outlook/settings.py)
# ------------------------------------------------------------------------------

# Azure Active Directory app registration credentials.
# Register your app at: https://portal.azure.com → Azure AD → App registrations
# Set redirect URI type to: Public client / native

OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback


# ------------------------------------------------------------------------------
# IBM Bob (app/bob/service.py)
# ------------------------------------------------------------------------------

BOB_API_URL=
BOB_API_KEY=


# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# MongoDB or Redis connection string (required for production).
# Leave empty for local development — InMemoryTokenRepository is used instead.
DATABASE_URL=


# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ------------------------------------------------------------------------------
# Slack Connector (app/connectors/slack/settings.py) — teammate's responsibility
# ------------------------------------------------------------------------------

# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=http://localhost:8000/api/v1/auth/slack/callback
