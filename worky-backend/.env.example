# ==============================================================================
# Worky Backend — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in all required values before running.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — it is listed in .gitignore.
# This file (.env.example) is safe to commit — it contains no real secrets.
# ==============================================================================


# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

APP_NAME=worky-backend
APP_ENV=development
APP_PORT=8000


# ------------------------------------------------------------------------------
# API
# ------------------------------------------------------------------------------

# Versioned API prefix — all routes are mounted under this path.
API_V1_PREFIX=/api/v1


# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------

# Base URL of the React / desktop widget frontend.
# When set, the OAuth callback redirects the browser to:
#   {FRONTEND_URL}/auth/success?user_id=...&display_name=...&email=...
# When left empty, the callback returns AuthorizationResponse JSON instead
# (backward-compatible default — safe for API clients and automated tests).
# Must NOT have a trailing slash.
FRONTEND_URL=http://localhost:3000


# ------------------------------------------------------------------------------
# Security — Token Encryption
# ------------------------------------------------------------------------------

# Fernet symmetric key used to encrypt OAuth refresh tokens before persistence.
# Generate a key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key invalidates all stored refresh tokens — users must re-login.
TOKEN_ENCRYPTION_KEY=


# ------------------------------------------------------------------------------
# Microsoft Outlook (app/connectors/outlook/settings.py)
# ------------------------------------------------------------------------------

# Azure Active Directory app registration credentials.
# Register your app at: https://portal.azure.com → Azure AD → App registrations
# Set redirect URI type to: Web (required for confidential-client secret auth)

OUTLOOK_CLIENT_ID=

# Tenant ID controls which Microsoft identity endpoint is used:
#
#   consumers  — personal Microsoft Accounts (Outlook.com, Hotmail, Xbox,
#                or Gmail/Yahoo addresses used as MSA). Use this when the
#                user's account is NOT a work/school (Azure AD) account.
#                This is correct for challasreeja2004@gmail.com.
#
#   common     — both personal and work/school accounts (mixed tenants).
#                Use this if you want to support all account types.
#
#   <tenant-id> — a specific Azure AD tenant GUID or domain (e.g. contoso.com).
#                 Use this ONLY if all users belong to a single Azure AD tenant.
#                 Personal Microsoft Accounts will get 401 on Graph API calls
#                 when a specific tenant GUID is used here.
#
# Default for Worky personal use: consumers
OUTLOOK_TENANT_ID=consumers

OUTLOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Client secret for confidential-client token exchange (AADSTS7000218).
# Generate at: Azure Portal → App registrations → your app →
#              Certificates & secrets → Client secrets → + New client secret
# Copy the VALUE (not the Secret ID) immediately — it is only shown once.
OUTLOOK_CLIENT_SECRET=


# ------------------------------------------------------------------------------
# Connector Mode
# ------------------------------------------------------------------------------

# Controls which data source is used for Outlook data throughout the pipeline.
# Supported values:
#   outlook  (default) — full Microsoft OAuth + Graph API path
#   demo               — no credentials required; returns synthetic Outlook data
#
# Changing CONNECTOR_MODE is the only configuration change needed to switch modes.
CONNECTOR_MODE=outlook


# ------------------------------------------------------------------------------
# IBM Bob Shell (app/bob/cli_service.py)
# ------------------------------------------------------------------------------

# Path or name of the bob CLI command.
# Defaults to "bob" (resolved via PATH).
# Override to an absolute path if bob is not on PATH in your deployment.
BOB_EXECUTABLE=bob

# Bob chat mode for reasoning calls.
# "ask" is read-only and cannot modify files or run commands.
# Valid choices: ask | code | plan | advanced
BOB_CHAT_MODE=ask

# Total seconds to wait for Bob to respond.
# Bob generation typically takes 15–30 s. 120 s is a safe production ceiling.
BOB_TIMEOUT_SECONDS=120

# Legacy — no longer used by BobCLIService. Kept so existing .env files remain valid.
BOB_API_URL=
BOB_API_KEY=


# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# MongoDB or Redis connection string (required for production).
# Leave empty for local development — InMemoryTokenRepository is used instead.
DATABASE_URL=


# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ------------------------------------------------------------------------------
# Slack Connector (app/connectors/slack/settings.py)
# ------------------------------------------------------------------------------

# Bot token from https://api.slack.com/apps → your app → OAuth & Permissions
# Required scopes: channels:read, groups:read, channels:history, groups:history
SLACK_BOT_TOKEN=

# Comma-separated list of Slack channel IDs to fetch messages from.
# Leave empty to fetch all channels the bot can access.
# Find a channel ID: right-click channel → View channel details → bottom of About tab.
# Example: SLACK_ALLOWED_CHANNEL_IDS=C012AB3CD,C999XYZ12
SLACK_ALLOWED_CHANNEL_IDS=


# ------------------------------------------------------------------------------
# GitHub Connector (app/connectors/github/settings.py)
# ------------------------------------------------------------------------------

# Personal Access Token (PAT) or OAuth token with the `repo` scope.
# Generate a fine-grained PAT at: https://github.com/settings/tokens
# Required scope: repo (or public_repo for public repositories only).
GITHUB_ACCESS_TOKEN=

# Optional: override for GitHub Enterprise Server deployments.
# Leave empty to use the default https://api.github.com.
GITHUB_API_BASE_URL=

# Maximum number of PRs to enrich per run (caps API cost).
# Defaults to 20 when unset.
GITHUB_MAX_PRS=20
